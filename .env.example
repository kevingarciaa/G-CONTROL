# GControl - Variáveis de ambiente
# Copie para .env e preencha com seus valores

# Django
DJANGO_SECRET_KEY=sua-chave-secreta-aqui-para-producao
DEBUG=True

# PostgreSQL (desenvolvimento local)
# Formato: postgresql://USER:SENHA@HOST:PORTA/NOME_DO_BANCO
# No Render: DATABASE_URL é injetada automaticamente
DATABASE_URL=postgresql://postgres:senha@localhost:5432/gcontrol
